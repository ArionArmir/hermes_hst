# Ambiente virtuale
venv/
env/
.venv/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Log e dati
logs/
*.log
*.csv
data/
*.db
*.sqlite

# Eccezione: i referti degli esperimenti sono quaderni di laboratorio, non dati
# derivati. Senza versionarli si perde il conteggio dei tentativi, e senza
# quello il Deflated Sharpe non e' calcolabile (vedi src/shared/holdout.py).
!docs/*.csv

# File di sistema
.DS_Store
Thumbs.db

# Librerie e file binari
*.so
*.dylib
*.dll
*.exe
hermes/lib/*
hermes/bin/*
site/

# File di configurazione sensibili
.env
*.key
*.pem

# Dashboard: PID dei processi gestiti da process_manager.py
dashboard/pids/
hermes/lib/python3.12/site-packages/pip/_internal/main.py
site/sitemap.xml.gz
dump.rdb
