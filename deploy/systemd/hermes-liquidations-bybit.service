[Unit]
Description=Hermes - Registratore liquidazioni Bybit (allLiquidation, verita' completa)
After=network-online.target redis-server.service

[Service]
WorkingDirectory=%h/hermes_hft
EnvironmentFile=-%h/hermes_hft/.env
ExecStart=%h/hermes_hft/venv/bin/python -m src.liquidations.bybit
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
